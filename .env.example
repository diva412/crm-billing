# Supabase connection strings
# DATABASE_URL uses the pooled connection (port 6543) for serverless/runtime queries
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"
# DIRECT_URL uses the direct connection (port 5432), required by Prisma for migrations
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Auth
JWT_SECRET="replace-with-a-long-random-string"

# Default admin (used by the seed script)
DEFAULT_ADMIN_EMAIL="admin@ritssoftware.com"
DEFAULT_ADMIN_PASSWORD="ChangeMe123!"
